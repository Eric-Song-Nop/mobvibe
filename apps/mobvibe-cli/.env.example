# === 网关连接 ===
# MOBVIBE_GATEWAY_URL=http://localhost:3005 # Gateway URL（默认: https://api.mobvibe.net）

# === 路径与标识 ===
# MOBVIBE_HOME=~/.mobvibe                  # 配置目录
# MOBVIBE_MACHINE_ID=                      # 机器标识符（默认自动生成）

# === 认证覆盖 ===
# MOBVIBE_MASTER_SECRET=                   # Base64 主密钥（覆盖凭证文件）

# === Shell ===
# MOBVIBE_SHELL=                           # 命令执行 Shell（默认: $SHELL 或 /bin/sh）

# === Agent 配置 ===
# MOBVIBE_ENABLED_AGENTS=                  # 逗号分隔的启用代理列表

# === WAL 配置 ===
# MOBVIBE_COMPACTION_ENABLED=false         # 自动事件压缩
# MOBVIBE_CONSOLIDATION_ENABLED=true       # WAL 事件合并

# === 日志 ===
# LOG_LEVEL=info                           # 日志级别: debug | info | warn | error
