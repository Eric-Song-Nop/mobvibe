# === 核心配置 ===
PORT=3005                                  # 服务器监听端口（或 GATEWAY_PORT）
LOG_LEVEL=info                             # 日志级别: debug | info | warn | error

# === 数据库 ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mobvibe

# === 认证 ===
BETTER_AUTH_SECRET=change-me-to-a-random-string
SITE_URL=http://localhost:3005             # 认证回调 URL

# === CORS ===
GATEWAY_CORS_ORIGINS=http://localhost:5173 # 逗号分隔的额外 CORS 源

# === 邮件（可选） ===
# RESEND_API_KEY=                          # Resend API 密钥；未设置时日志输出
# EMAIL_FROM=Mobvibe <noreply@example.com> # 发件人地址
SKIP_EMAIL_VERIFICATION=true               # 开发环境跳过邮件验证

# === GitHub OAuth（可选） ===
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# === 多实例部署（可选，单实例无需设置） ===
# REDIS_URL=                               # Upstash Redis URL；设置后启用用户亲和性路由

# === Fly.io（平台自动注入，无需手动设置） ===
# FLY_ALLOC_ID=                            # 实例标识符
# FLY_REGION=                              # 区域标识符
# FLY_APP_NAME=                            # 应用名称（推导 SITE_URL）
# IS_PREVIEW=false                         # 预览模式
