# Gateway Development Environment (committed defaults)
# Local overrides with secrets go in .env (gitignored)

SITE_URL=http://localhost:3005
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mobvibe
BETTER_AUTH_SECRET=dev-secret-change-me
GATEWAY_CORS_ORIGINS=http://localhost:5173
SKIP_EMAIL_VERIFICATION=true
LOG_LEVEL=debug

# Resend email (optional for dev)
# RESEND_API_KEY=
# EMAIL_FROM=Mobvibe <noreply@example.com>

# Multi-instance (optional)
# REDIS_URL=redis://...
